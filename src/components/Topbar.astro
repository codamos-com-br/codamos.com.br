---
/**
 * Header/topbar — ports technews partials/top.hbs.
 *
 * Note: the `.content` grid wrapper and the infobar were moved to BaseLayout so
 * the wrapper spans the whole page (main + sidebar + footer). Astro balances
 * each component's template, so opening `.content` here would auto-close it at
 * the end of this file and break the grid.
 */
import { SITE } from '../lib/site';
import Menu from './Menu.astro';

export interface Props {
  lastUpdate?: Date;
}
// lastUpdate is accepted for API compatibility but rendered by BaseLayout.
---

<header class="topbar" id="js-header">
  <div class="topbar__inner">
    <a class="logo" href="/">
      <img src={SITE.logo} alt={SITE.name} />
    </a>
    <Menu />
  </div>
</header>
