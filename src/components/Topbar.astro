---
/**
 * Header/topbar — ports technews partials/top.hbs.
 * Includes the (previously hidden) infobar search input, now wired to Pagefind (#14).
 */
import { SITE } from '../lib/site';
import Menu from './Menu.astro';

export interface Props {
  lastUpdate?: Date;
}
const { lastUpdate } = Astro.props;
const lastUpdateIso = lastUpdate?.toISOString();
const lastUpdateLabel = lastUpdate
  ? new Intl.DateTimeFormat('pt-BR', { day: 'numeric', month: 'long', year: 'numeric' }).format(
      lastUpdate
    )
  : '';
---

<header class="topbar" id="js-header">
  <div class="topbar__inner">
    <a class="logo" href={SITE.domain}>
      <img src={SITE.logo} alt={SITE.name} />
    </a>
    <Menu />
  </div>
</header>
<div class="content">
  <div class="infobar">
    {
      lastUpdate && (
        <div class="infobar__update">
          Última atualização:
          <time datetime={lastUpdateIso}>{lastUpdateLabel}</time>
        </div>
      )
    }
    <div class="infobar__search">
      <form action="/search/">
        <input
          type="search"
          name="q"
          placeholder="Buscar..."
          aria-label="Buscar"
        />
        <button type="submit" aria-label="Buscar">
          <svg role="presentation" focusable="false" width="15px" height="14px">
            <use xlink:href="/assets/svg/svg-map.svg#search"></use>
          </svg>
        </button>
      </form>
    </div>
  </div>
