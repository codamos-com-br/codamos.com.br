---
/** Shared card grid (layout 2col-1-4) used by home, tag and author listings. */
import type { Post } from '../lib/content';
import Card from './Card.astro';
import Pagination from './Pagination.astro';

export interface Props {
  posts: Post[];
  firstIsH1?: boolean;
  prevUrl?: string;
  nextUrl?: string;
}
const { posts, firstIsH1 = false, prevUrl, nextUrl } = Astro.props;
const hasPagination = Boolean(prevUrl || nextUrl);
---

<main class="main l-grid l-grid--2col-1-4">
  {
    posts.map((post, i) => (
      <Card post={post} heading={firstIsH1 && i === 0 ? 'h1' : 'h5'} />
    ))
  }
  {hasPagination && <Pagination prevUrl={prevUrl} nextUrl={nextUrl} extraClass="2col__2span" />}
</main>
