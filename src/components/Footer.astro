---
/**
 * Footer — ports technews partials/footer.hbs. Rendered inside the `.content`
 * grid wrapper (opened/closed in BaseLayout), then emits the menu-config +
 * theme scripts. (No footer menu is configured in Publii; footer social
 * buttons are off.)
 */
import { SITE } from '../lib/site';
---

<footer class="footer">
  <a class="footer__logo" href="/">
    <img src={SITE.logo} alt={SITE.name} />
  </a>
  <div class="footer__copyright">
    <p>{SITE.copyright}</p>
  </div>
</footer>

<script is:inline>
  window.publiiThemeMenuConfig = {
    mobileMenuMode: 'sidebar',
    animationSpeed: 300,
    submenuWidth: 'auto',
    doubleClickTime: 500,
    mobileMenuExpandableSubmenus: true,
    relatedContainerForOverlayMenuSelector: '.navbar',
  };
</script>
<script defer src="/assets/js/scripts.min.js"></script>
<script is:inline>
  // Lazy-load 'is-loaded' fade-in (Publii mediaLazyLoad behaviour).
  var images = document.querySelectorAll('img[loading]');
  for (var i = 0; i < images.length; i++) {
    if (images[i].complete) {
      images[i].classList.add('is-loaded');
    } else {
      images[i].addEventListener(
        'load',
        function () {
          this.classList.add('is-loaded');
        },
        false
      );
    }
  }
</script>
