---
/**
 * Client-side search (#14) via Pagefind. The index is generated at build time
 * (`pagefind --site dist`, see package.json build script) over post bodies
 * marked with data-pagefind-body. The header form GETs here with ?q=, which we
 * forward into the Pagefind UI on load. noindex per Publii metaRobotsSearch.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import Sidebar from '../../components/Sidebar.astro';
import { META, fillTemplate } from '../../lib/site';
---

<BaseLayout title={fillTemplate(META.searchTitle, {})} robots={META.robotsSearch}>
  <main class="main">
    <div class="page search">
      <h1 class="page__title box__title">Busca</h1>
    </div>
    <div id="search" class="search__pagefind"></div>
  </main>
  <Sidebar />
</BaseLayout>

<link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
<script is:inline src="/pagefind/pagefind-ui.js"></script>
<script is:inline>
  function initQuery() {
    var params = new URLSearchParams(window.location.search);
    var q = params.get('q') || '';
    if (!q) return;
    var input = document.querySelector('#search .pagefind-ui__search-input');
    if (input) {
      input.value = q;
      input.dispatchEvent(new Event('input', { bubbles: true }));
    }
  }
  window.addEventListener('DOMContentLoaded', function () {
    if (typeof PagefindUI === 'undefined') return;
    new PagefindUI({
      element: '#search',
      showSubResults: true,
      showImages: true,
      translations: {
        placeholder: 'Buscar no codamos.com.br',
        clear_search: 'Limpar',
        load_more: 'Carregar mais resultados',
        search_label: 'Buscar neste site',
        filters_label: 'Filtros',
        zero_results: 'Nenhum resultado para [SEARCH_TERM]',
        many_results: '[COUNT] resultados para [SEARCH_TERM]',
        one_result: '[COUNT] resultado para [SEARCH_TERM]',
        alt_search: 'Nenhum resultado para [SEARCH_TERM]. Mostrando resultados para [DIFFERENT_TERM]',
        search_suggestion: 'Nenhum resultado para [SEARCH_TERM]. Tente uma das buscas a seguir:',
        searching: 'Buscando por [SEARCH_TERM]...',
      },
    });
    initQuery();
  });
</script>
