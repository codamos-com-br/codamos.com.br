---
/**
 * Root layout — composes head + topbar + a single `.content` grid wrapper
 * (infobar + page slot + footer) + consent banner + gated analytics. Mirrors
 * the technews head.hbs → top.hbs → <page> → footer.hbs assembly.
 *
 * The `.content` wrapper lives here (not split across Topbar/Footer): Astro
 * balances each component's template independently, so a `<div>` opened in
 * Topbar would be auto-closed at the end of Topbar — dropping the main column,
 * sidebar and footer out of the grid. Keeping the wrapper in one component
 * makes `main` + `sidebar` + `footer` real grid children again.
 */
import { SITE } from '../lib/site';
import BaseHead, { type Props as HeadProps } from '../components/BaseHead.astro';
import Topbar from '../components/Topbar.astro';
import Footer from '../components/Footer.astro';
import CookieConsent from '../components/CookieConsent.astro';
import Analytics from '../components/Analytics.astro';

export interface Props extends HeadProps {
  lastUpdate?: Date;
}

const { lastUpdate, ...head } = Astro.props;
const lastUpdateIso = lastUpdate?.toISOString();
const lastUpdateLabel = lastUpdate
  ? new Intl.DateTimeFormat('pt-BR', { day: 'numeric', month: 'long', year: 'numeric' }).format(
      lastUpdate
    )
  : '';
---

<!doctype html>
<html lang={SITE.language}>
  <head>
    <BaseHead {...head} />
  </head>
  <body>
    <Topbar lastUpdate={lastUpdate} />
    <div class="content">
      {
        lastUpdate && (
          <div class="infobar">
            <div class="infobar__update">
              Última atualização:
              <time datetime={lastUpdateIso}>{lastUpdateLabel}</time>
            </div>
          </div>
        )
      }
      <slot />
      <Footer />
    </div>
    <CookieConsent />
    <Analytics />
  </body>
</html>
