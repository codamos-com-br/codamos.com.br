---
/**
 * Root layout — composes head + topbar (opens .content) + page slot + footer
 * (closes .content) + consent banner + gated analytics. Mirrors the technews
 * head.hbs → top.hbs → <page> → footer.hbs assembly.
 */
import { SITE } from '../lib/site';
import BaseHead, { type Props as HeadProps } from '../components/BaseHead.astro';
import Topbar from '../components/Topbar.astro';
import Footer from '../components/Footer.astro';
import CookieConsent from '../components/CookieConsent.astro';
import Analytics from '../components/Analytics.astro';

export interface Props extends HeadProps {
  lastUpdate?: Date;
}

const { lastUpdate, ...head } = Astro.props;
---

<!doctype html>
<html lang={SITE.language}>
  <head>
    <BaseHead {...head} />
  </head>
  <body>
    <Topbar lastUpdate={lastUpdate} />
    <slot />
    <Footer />
    <CookieConsent />
    <Analytics />
  </body>
</html>
