{
  "name": "codamos.com.br",
  "type": "module",
  "version": "1.0.0",
  "description": "codamos.com.br — blog sobre desenvolvimento de software (Astro)",
  "scripts": {
    "import": "node scripts/import-content.mjs",
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build && pagefind --site dist",
    "preview": "astro preview",
    "astro": "astro",
    "format": "prettier --write \"src/**/*.{astro,ts,js,mjs,css}\" \"scripts/**/*.mjs\""
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.11",
    "@astrojs/sitemap": "^3.2.1",
    "astro": "^5.7.0"
  },
  "devDependencies": {
    "better-sqlite3": "^11.8.1",
    "pagefind": "^1.3.0",
    "prettier": "^3.4.2",
    "prettier-plugin-astro": "^0.14.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
